{
  "name": "@nomic/vscode-extension",
  "version": "0.1.0",
  "private": true,
  "displayName": "Nomic",
  "description": "Context orchestration for coding agents.",
  "main": "dist/extension.js",
  "engines": {
    "vscode": "^1.97.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:nomic.indexWorkspace",
    "onCommand:nomic.compileContext"
  ],
  "contributes": {
    "commands": [
      {
        "command": "nomic.indexWorkspace",
        "title": "Nomic: Index Workspace"
      },
      {
        "command": "nomic.compileContext",
        "title": "Nomic: Compile Context"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nomic/core": "0.1.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.97.0"
  }
}
