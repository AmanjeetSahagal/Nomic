{
  "name": "@nomic/vscode-extension",
  "version": "0.1.0",
  "private": true,
  "displayName": "Nomic",
  "description": "Context orchestration for coding agents.",
  "main": "dist/extension.js",
  "engines": {
    "vscode": "^1.97.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:nomic.preview",
    "onCommand:nomic.indexWorkspace",
    "onCommand:nomic.compileContext",
    "onCommand:nomic.refreshPreview",
    "onCommand:nomic.copyPayload",
    "onCommand:nomic.openPayload",
    "onCommand:nomic.openCompiledPrompt",
    "onCommand:nomic.sendToAgent"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nomic",
          "title": "Nomic",
          "icon": "media/vscode_grey_logo.png"
        }
      ]
    },
    "views": {
      "nomic": [
        {
          "id": "nomic.preview",
          "name": "Prompt Preview",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "nomic.indexWorkspace",
        "title": "Nomic: Index Workspace"
      },
      {
        "command": "nomic.compileContext",
        "title": "Nomic: Compile Context"
      },
      {
        "command": "nomic.refreshPreview",
        "title": "Nomic: Refresh Preview"
      },
      {
        "command": "nomic.copyPayload",
        "title": "Nomic: Copy Payload"
      },
      {
        "command": "nomic.openPayload",
        "title": "Nomic: Open Payload"
      },
      {
        "command": "nomic.openCompiledPrompt",
        "title": "Nomic: Open Compiled Prompt"
      },
      {
        "command": "nomic.sendToAgent",
        "title": "Nomic: Approve And Send To Agent"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nomic/core": "0.1.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.97.0"
  }
}
